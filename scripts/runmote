#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
INSTALL_DIR="$(cd "$SELF_DIR/.." && pwd)"
PYTHON="$INSTALL_DIR/.venv/bin/python"

# ── Color setup ──────────────────────────────────────────────────────
if [[ -t 1 ]] && [[ -t 0 ]]; then
    n() { printf '\033[%sm' "$1"; }
    BOLD="$(n 1)"; DIM="$(n 2)"; RESET="$(n 0)"
    RED="$(n 31)"; GREEN="$(n 32)"; YELLOW="$(n 33)"
    BLUE="$(n 34)"; CYAN="$(n 36)"; WHITE="$(n 97)"
else
    n() { :; }
    BOLD=""; DIM=""; RESET=""; RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; WHITE=""
fi

ESC=$'\033'

case "$(uname -s)" in
    Linux)   OS="linux" ;;
    Darwin)  OS="darwin" ;;
    MINGW*|MSYS*|CYGWIN*) OS="windows" ;;
    *)       echo "Error: unsupported OS"; exit 1 ;;
esac

# ── Daemon control ───────────────────────────────────────────────────
get_daemon_name() {
    if [[ -n "${ACP_DAEMON_ID:-}" ]]; then echo "$ACP_DAEMON_ID"
    elif command -v hostname &>/dev/null; then hostname
    else uname -n; fi
}

start_daemon() {
    case "$OS" in
        linux)   systemctl --user start runmote.service 2>/dev/null ;;
        darwin)  launchctl start com.runmote.daemon 2>/dev/null || true ;;
        windows) powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SELF_DIR/runmote.ps1" -Start; return ;;
    esac
    echo "  ${GREEN}Daemon started.${RESET}"
}

stop_daemon() {
    case "$OS" in
        linux)   systemctl --user stop runmote.service 2>/dev/null ;;
        darwin)  launchctl stop com.runmote.daemon 2>/dev/null || true ;;
        windows) powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SELF_DIR/runmote.ps1" -Stop; return ;;
    esac
    echo "  ${YELLOW}Daemon stopped.${RESET}"
}

is_running() {
    case "$OS" in
        linux)   systemctl --user is-active --quiet runmote.service 2>/dev/null ;;
        darwin)  launchctl list com.runmote.daemon &>/dev/null ;;
        windows) powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \
            "Get-ScheduledTask -TaskName 'Runmote Daemon' -ErrorAction SilentlyContinue | Where-Object State -eq 'Running'" 2>/dev/null | grep -q Running ;;
    esac
}

get_pairing_code() {
    case "$OS" in
        linux)   journalctl --user -u runmote.service -n 100 --no-pager 2>/dev/null | grep -oP 'pairing code:\s+\K\S+' | tail -1 ;;
        darwin)  grep -oP 'pairing code:\s+\K\S+' ~/Library/Logs/runmote-daemon.log 2>/dev/null | tail -1 ;;
        windows) powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \
            "Select-String -Path (\"\$env:TEMP\runmote-daemon.log\") -Pattern 'pairing code:\s+(\S+)' | Select-Object -Last 1 | ForEach-Object { \$_.Matches.Groups[1].Value }" 2>/dev/null ;;
    esac
}

# ── Pairing code display ─────────────────────────────────────────────
show_code_fallback() {
    local formatted="${code:0:4}-${code:4}"
    echo ""
    echo "  ${BOLD}┌─────────────────────────────┐${RESET}"
    printf "  ${BOLD}│${RESET}  ${CYAN}Pairing Code:${RESET} ${GREEN}${BOLD}%-12s${RESET}  ${BOLD}│${RESET}\n" "$formatted"
    echo "  ${BOLD}│${RESET}                             ${BOLD}│${RESET}"
    echo "  ${BOLD}│${RESET}  ${DIM}Enter this in the app${RESET}      ${BOLD}│${RESET}"
    echo "  ${BOLD}└─────────────────────────────┘${RESET}"
    echo ""
}

regenerate_code() {
    echo "  ${DIM}Restarting daemon to generate a new pairing code...${RESET}" >&2
    local old_code=""
    old_code=$(get_pairing_code)
    stop_daemon >&2
    sleep 1
    local temp_file="/tmp/runmote-pairing-code.txt"
    [[ "$OS" == "windows" ]] && temp_file="$TEMP/runmote-pairing-code.txt"
    rm -f "$temp_file"
    start_daemon >&2
    local code=""
    for i in $(seq 1 15); do
        sleep 1
        if [[ -f "$temp_file" ]]; then
            code=$(head -1 "$temp_file" 2>/dev/null)
        fi
        [[ -z "$code" ]] && code=$(get_pairing_code)
        [[ -n "$code" ]] && [[ "$code" != "$old_code" ]] && break
        code=""
    done
    if [[ -z "$code" ]]; then
        echo "  ${RED}Could not retrieve new pairing code. Is the daemon connected?${RESET}" >&2
        return 1
    fi
    echo "$code"
}

show_code_only() {
    local code=$(regenerate_code)
    if [[ -z "$code" ]]; then
        return 1
    fi
    show_code_fallback
}

show_qr() {
    local code=$(regenerate_code)
    if [[ -z "$code" ]]; then
        return 1
    fi
    if [[ -z "$code" ]]; then
        echo "  ${RED}Could not retrieve pairing code. Is the daemon connected?${RESET}"
        return 1
    fi
    echo ""
    local public_url=""
    if [[ -f "$HOME/.config/runmote/public_url" ]]; then
        public_url="$(cat "$HOME/.config/runmote/public_url")"
    fi
    if [[ -f "$PYTHON" ]] && [[ -d "$INSTALL_DIR/src" ]]; then
        "$PYTHON" -c "
import sys; sys.path.insert(0, '$INSTALL_DIR/src')
from daemon.main import _pairing_banner
print(_pairing_banner('$code', '$public_url'))
" 2>/dev/null && return 0
    fi
    show_code_fallback
}

# ── Uninstall ────────────────────────────────────────────────────────
uninstall_daemon() {
    echo ""
    read -r -p "  ${RED}${BOLD}Uninstall Runmote daemon?${RESET} This removes all files and auto-start. ${DIM}[y/N]${RESET}: " confirm
    case "${confirm,,}" in
        y|yes) ;;
        *) echo "  ${DIM}Cancelled.${RESET}"; return 0 ;;
    esac

    echo ""
    echo "  Stopping daemon..."
    stop_daemon 2>/dev/null || true

    echo "  Removing auto-start..."
    case "$OS" in
        linux)
            systemctl --user disable --now runmote.service 2>/dev/null || true
            rm -f "$HOME/.config/systemd/user/runmote.service"
            systemctl --user daemon-reload 2>/dev/null || true ;;
        darwin)
            launchctl unload -w "$HOME/Library/LaunchAgents/com.runmote.daemon.plist" 2>/dev/null || true
            rm -f "$HOME/Library/LaunchAgents/com.runmote.daemon.plist" ;;
        windows)
            powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SELF_DIR/setup-autostart.ps1" -Remove ;;
    esac

    echo "  Removing runmote command..."
    rm -f "$HOME/.local/bin/runmote"

    echo "  Removing $INSTALL_DIR..."
    rm -rf "$INSTALL_DIR"

    echo ""
    echo "  ${GREEN}Runmote daemon uninstalled.${RESET}"
}

# ── Logo ─────────────────────────────────────────────────────────────
_logo() {
    echo ""
    echo "  ${BOLD}${CYAN}██████╗ ██╗   ██╗███╗   ██╗███╗   ███╗ ██████╗ ████████╗███████╗${RESET}"
    echo "  ${BOLD}${CYAN}██╔══██╗██║   ██║████╗  ██║████╗ ████║██╔═══██╗╚══██╔══╝██╔════╝${RESET}"
    echo "  ${BOLD}${CYAN}██████╔╝██║   ██║██╔██╗ ██║██╔████╔██║██║   ██║   ██║   █████╗  ${RESET}"
    echo "  ${BOLD}${CYAN}██╔══██╗██║   ██║██║╚██╗██║██║╚██╔╝██║██║   ██║   ██║   ██╔══╝  ${RESET}"
    echo "  ${BOLD}${CYAN}██║  ██║╚██████╔╝██║ ╚████║██║ ╚═╝ ██║╚██████╔╝   ██║   ███████╗${RESET}"
    echo "  ${BOLD}${CYAN}╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═══╝╚═╝     ╚═╝ ╚═════╝    ╚═╝   ╚══════╝${RESET}"
    echo ""
    echo "  ${DIM}Runmote${RESET}"
    echo ""
}

# ── Menu (arrow-key TTY) ────────────────────────────────────────────
_menu_draw() {
    local sel=$1 W=42
    local hl hl_off name
    hl="${BOLD}${ESC}[7m"
    hl_off="${ESC}[0m${RESET}"
    name="$(get_daemon_name)"

    local status_color status_text
    if is_running; then
        status_color="${GREEN}"; status_text="● RUNNING"
    else
        status_color="${RED}"; status_text="● STOPPED"
    fi

    box_top() { echo "  ${BOLD}${CYAN}╔$(printf '═%.0s' $(eval "echo {1..$W}"))╗${RESET}"; }
    box_mid() { echo "  ${BOLD}${CYAN}╠$(printf '═%.0s' $(eval "echo {1..$W}"))╣${RESET}"; }
    box_bot() { echo "  ${BOLD}${CYAN}╚$(printf '═%.0s' $(eval "echo {1..$W}"))╝${RESET}"; }
    _strip_ansi() { printf '%s' "$1" | sed 's/'$'\033''\[[0-9;]*[a-zA-Z]//g'; }
    _vlen() { _strip_ansi "$1" | wc -m; }
    box_row() { local c="$1" v vpad; v=$(_vlen "$c"); vpad=$((W - v)); printf "  ${BOLD}${CYAN}║${RESET}%s%*s${BOLD}${CYAN}║${RESET}\n" "$1" "$vpad" ""; }

    local dot="${CYAN}·${RESET}"
    local items=(
        ""
        "    ${CYAN}Start${RESET} daemon"
        "    ${RED}Stop${RESET} daemon"
        "    Show pairing ${CYAN}QR code${RESET}"
        "    Show pairing ${CYAN}code${RESET} ${DIM}(text)${RESET}"
        "    ${RED}Uninstall${RESET} daemon"
        "    Quit"
    )

    box_top
    box_row "    ${WHITE}${BOLD}Runmote Daemon Control${RESET}"
    box_mid
    box_row "    ${status_color}${status_text}${RESET}"
    box_row "    ${DIM}Daemon: ${name}${RESET}"
    box_mid

    local i
    for i in 1 2 3 4 5 6; do
        if [[ $i -eq $sel ]]; then
            box_row "${hl}  ${dot} ${items[$i]:4}${hl_off}"
        else
            box_row "${items[$i]}"
        fi
    done

    box_bot
    echo ""
    echo "  ${DIM}↑↓ navigate  ↵ select  q quit${RESET}"
}

_exec_action() {
    case $1 in
        1) start_daemon; sleep 1 ;;
        2) stop_daemon; sleep 1 ;;
        3) show_qr; echo ""; read -r -p "  Press Enter to continue..." _ ;;
        4) show_code_only; echo ""; read -r -p "  Press Enter to continue..." _ ;;
        5) uninstall_daemon; return 1 ;;
        6) echo ""; exit 0 ;;
    esac
    return 0
}

show_menu() {
    if [[ ! -t 0 ]]; then
        # Non-TTY fallback: number-based menu
        while true; do
            local status_color status_text name
            if is_running; then status_color="${GREEN}"; status_text="● RUNNING"
            else status_color="${RED}"; status_text="● STOPPED"; fi
            name="$(get_daemon_name)"

            echo ""
            echo "  ${BOLD}${CYAN}Runmote Daemon Control${RESET}  ${status_color}${status_text}${RESET}  ${DIM}Daemon: ${name}${RESET}"
            echo ""
            echo "  1) Start daemon        2) Stop daemon"
            echo "  3) Show QR code        4) Show code (text)"
            echo "  5) Uninstall daemon    q) Quit"
            echo ""
            read -r -p "  Choice: " choice || exit 0
            case "$choice" in
                1) echo ""; start_daemon; sleep 1 ;;
                2) echo ""; stop_daemon; sleep 1 ;;
                3) echo ""; show_qr; echo ""; read -r -p "  Press Enter to continue..." _ ;;
                4) echo ""; show_code_only; echo ""; read -r -p "  Press Enter to continue..." _ ;;
                5) uninstall_daemon; return ;;
                q|Q) echo ""; exit 0 ;;
                *) echo "  Invalid choice"; sleep 1 ;;
            esac
        done
    fi

    # TTY: arrow-key menu
    local sel=1
    local old_stty=$(stty -g) 2>/dev/null || true
    stty -echo -icanon min 1 time 0 2>/dev/null || true
    trap 'stty "${old_stty:-}" 2>/dev/null; printf "${ESC}[2J${ESC}[H${ESC}[?1049l${ESC}[2J${ESC}[H"' EXIT

    printf "${ESC}[?1049h"
    printf "${ESC}[H${ESC}[J"
    _logo
    printf "${ESC}[s"
    _menu_draw $sel

    while true; do
        local key=""
        IFS= read -rsn1 key 2>/dev/null || true

        case "$key" in
            $'\033')
                read -rsn2 -t 0.01 key2 2>/dev/null || true
                case "$key2" in
                    '[A') ((sel > 1)) && ((sel--)) ;;
                    '[B') ((sel < 6)) && ((sel++)) ;;
                esac
                ;;
            q|Q)
                exit 0
                ;;
            $'\n'|$'\r'|'')
                stty "$old_stty" 2>/dev/null
                printf "${ESC}[?1049l${ESC}[0m"
                echo
                if ! _exec_action $sel; then return; fi
                stty -echo -icanon min 1 time 0 2>/dev/null || true
                printf "${ESC}[2J${ESC}[H"
                printf "${ESC}[?1049h"
                _logo
                printf "${ESC}[s"
                ;;
        esac

        printf "${ESC}[u${ESC}[J"
        _menu_draw $sel
    done
}

# ── CLI dispatch ─────────────────────────────────────────────────────
case "${1:-}" in
    start)     start_daemon; exit 0 ;;
    stop)      stop_daemon; exit 0 ;;
    code)      show_qr; exit $? ;;
    text)      show_code_only; exit $? ;;
    uninstall) uninstall_daemon; exit $? ;;
    status)
        name=$(get_daemon_name)
        if is_running; then
            echo "${GREEN}●${RESET} Daemon: RUNNING (${name})"
        else
            echo "${RED}●${RESET} Daemon: STOPPED (${name})"
        fi
        exit 0 ;;
    "")     show_menu ;;
    *)      echo "Usage: runmote [start|stop|code|text|uninstall|status]"
            echo "       runmote          (interactive menu)"
            exit 1 ;;
esac
